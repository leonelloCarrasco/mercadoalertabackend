# Base de datos (ejemplo con Supabase — usa el connection string en modo "Transaction" del pooler)
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:tu-password@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# Autenticación
JWT_SECRET=cambia-esto-por-algo-largo-y-aleatorio

# API key para proteger las rutas /api/admin/* (invéntate un valor largo y random)
ADMIN_API_KEY=cambia-esto-por-otro-valor-largo-y-aleatorio

# API Mercado Público
MERCADOPUBLICO_TICKET=tu-ticket-real
COMPRAAGIL_TICKET=tu-ticket-de-compra-agil

# MercadoPago — opcional en desarrollo (si falta, los pagos se simulan en consola)
MERCADOPAGO_ACCESS_TOKEN=tu-access-token-de-mercadopago
# Puerto del servidor (opcional, por defecto 3000)
PORT=3000

# URL donde vive el dashboard (opcional, por defecto https://dashboard.mercadoalerta.cl)
# Se usa para armar el link de recuperación de contraseña en el email.
FRONTEND_URL=https://dashboard.mercadoalerta.cl
